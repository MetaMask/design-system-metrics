{
  "name": "@georgewrmarshall/design-system-metrics",
  "version": "2.6.0",
  "description": "A CLI tool to audit design system component usage from local libraries, NPM packages, and track deprecated components across MetaMask codebases",
  "main": "index.js",
  "packageManager": "yarn@4.3.1",
  "bin": "./index.js",
  "scripts": {
    "start": "node index.js --project extension",
    "start:mobile": "node index.js --project mobile",
    "test": "jest",
    "test:watch": "jest --watch",
    "setup-repos": "git submodule update --init --recursive",
    "update-repos": "git submodule update --remote --merge",
    "sync-config": "node scripts/sync-config.js",
    "sync-config:dry-run": "node scripts/sync-config.js --dry-run",
    "sync-config:skip-update": "node scripts/sync-config.js --skip-update",
    "fetch-migration-targets": "node scripts/fetch-migration-list.js"
  },
  "keywords": [
    "cli",
    "audit",
    "components",
    "ast",
    "babel"
  ],
  "author": "George Marshall",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.25.7",
    "@babel/traverse": "^7.25.7",
    "brace-expansion": "^4.0.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "exceljs": "^4.4.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
